# ========================
# SMTP — Почтовый сервер
# ========================
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your@mail.ru
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your@mail.ru
SMTP_TLS=true

EMAIL_TO=your@mail.ru

# ========================
# Telegram Bot
# ========================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ID канала (узнать через @userinfobot, начинается с -100...)
TELEGRAM_CHANNEL_ID=-1002000000000

# Публичная ссылка на канал
TELEGRAM_CHANNEL_URL=https://t.me/your_channel

# Ваш личный chat_id (для получения уведомлений об ошибках)
TELEGRAM_EDITOR_CHAT_ID=123456789
